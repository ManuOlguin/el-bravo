datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

////////////////////
// ENUMS
////////////////////

enum GroupRole {
  admin
  member
}

enum MembershipStatus {
  pending
  accepted
  rejected
  removed
}

enum ActivityType {
  gym
  run
  sport
  mobility
  other
}

enum ScoreEventType {
  activity_base
  weekly_streak_bonus
  perfect_week_bonus
  award_bonus
  manual_adjustment
  penalty
}

enum AwardScope {
  season
  profile
}

////////////////////
// MODELS
////////////////////

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String?
  photoUrl     String? @db.VarChar(2048)

  // Perfil MVP
  weeklyGoal Int     @default(3)
  timezone   String? @db.VarChar(64)

  emailVerifiedAt DateTime?
  isActive        Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  // Relations
  groupMembers        GroupMember[]
  seasonMembers       SeasonMember[]
  activities          Activity[]
  routines            Routine[]
  scoreEvents         ScoreEvent[]
  seasonWeekProgress  SeasonWeekProgress[]
  awardsEarned        AwardEarned[]
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  photoUrl    String?  @db.VarChar(2048)

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  inviteCode          String?   @unique @db.VarChar(12)
  inviteCodeExpiresAt DateTime?

  // Relations
  members GroupMember[]
  seasons Season[]

  @@index([createdBy])
}

model GroupMember {
  id      String    @id @default(cuid())
  groupId String
  userId  String

  role   GroupRole
  status MembershipStatus @default(accepted)

  requestedAt DateTime?
  acceptedAt  DateTime?
  respondedAt DateTime?
  respondedBy String?

  joinedAt DateTime @default(now())
  leftAt   DateTime?

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId, status])
}

model Season {
  id          String   @id @default(cuid())
  groupId     String
  name        String
  description String?  @db.Text

  startDate DateTime
  endDate   DateTime

  createdBy String?
  createdAt DateTime @default(now())
  endedAt   DateTime?

  isActive Boolean @default(true)

  // Config MVP de competencia
  weeklyGoal Int @default(2)

  // Tipos admitidos; para MVP va en JSON
  allowedActivityTypes Json?

  // Fair play / caps
  maxScoreableMinutesPerDay      Int?
  maxScoreableMinutesPerActivity Int?

  // Config básica de scoring
  basePointsPerActivity Int @default(10)
  weeklyStreakBonus     Int @default(5)
  perfectWeekBonus      Int @default(15)

  // Relations
  group             Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  members           SeasonMember[]
  activitySeasons   ActivitySeason[]
  scoreEvents       ScoreEvent[]
  weekProgress      SeasonWeekProgress[]
  awardEarned       AwardEarned[]

  @@index([groupId])
  @@index([groupId, isActive])
  @@index([startDate, endDate])
}

model SeasonMember {
  id       String   @id @default(cuid())
  seasonId String
  userId   String
  joinedAt DateTime @default(now())
  leftAt   DateTime?

  // Relations
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  @@index([userId])
}

model Exercise {
  id   String @id @default(cuid())
  name String

  // Relations
  muscles    ExerciseMuscle[]
  routines   RoutineExercise[]
  activities ActivityExercise[]

  @@unique([name])
}

model Muscle {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  groupKey  String  @db.VarChar(64) // legs, chest, back, shoulders, arms, core, glutes, etc.

  exercises ExerciseMuscle[]

  @@unique([name])
}

model ExerciseMuscle {
  exerciseId String
  muscleId   String
  percentage Int

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  muscle   Muscle   @relation(fields: [muscleId], references: [id], onDelete: Cascade)

  @@id([exerciseId, muscleId])
  @@index([muscleId])
}

model Activity {
  id        String       @id @default(cuid())
  userId    String
  routineId String?
  type      ActivityType

  startedAt DateTime
  endedAt   DateTime
  durationMinutes Int?

  notes     String?      @db.Text
  source    String?      @db.VarChar(32)

  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  // Relations
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine         Routine?          @relation(fields: [routineId], references: [id], onDelete: SetNull)
  exercises       ActivityExercise[]
  media           ActivityMedia[]
  activitySeasons ActivitySeason[]
  scoreEvents     ScoreEvent[]
  awardsEarned    AwardEarned[]

  @@index([userId, startedAt])
  @@index([startedAt])
  @@index([type])
  @@index([routineId])
}

model ActivityMedia {
  id         String   @id @default(cuid())
  activityId String

  url        String   @db.VarChar(2048)
  storageKey String?  @db.VarChar(255)
  mimeType   String?  @db.VarChar(128)
  sizeBytes  Int?
  width      Int?
  height     Int?

  uploadedAt DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
}

model ActivitySeason {
  id         String   @id @default(cuid())
  activityId String
  seasonId   String
  createdAt  DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  season   Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([activityId, seasonId])
  @@index([seasonId])
}

model Routine {
  id   String @id @default(cuid())
  name String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activities Activity[]
  exercises  RoutineExercise[]

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@index([userId])
}

model RoutineExercise {
  id String @id @default(cuid())

  routineId  String
  exerciseId String

  sets Int
  reps Int
  weightKg Float?

  routine  Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([routineId])
  @@index([exerciseId])
}

model ActivityExercise {
  id String @id @default(cuid())

  activityId String
  exerciseId String

  sets Int
  reps Int
  weightKg Float?

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@index([exerciseId])
}

model ScoreEvent {
  id         String         @id @default(cuid())
  seasonId   String
  userId     String
  activityId String?
  weekStart  DateTime?
  type       ScoreEventType
  points     Int
  reason     String?        @db.Text
  metadata   Json?
  createdAt  DateTime       @default(now())

  season   Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@index([seasonId, userId])
  @@index([userId])
  @@index([activityId])
  @@index([seasonId, weekStart])
}

model SeasonWeekProgress {
  id              String   @id @default(cuid())
  seasonId        String
  userId          String
  weekStart       DateTime

  activitiesCount Int      @default(0)
  minutesTotal    Int      @default(0)

  goalTarget   Int
  goalReached  Boolean  @default(false)
  perfectWeek  Boolean  @default(false)
  streakCount  Int      @default(0)
  pointsEarned Int      @default(0)

  updatedAt DateTime? @updatedAt

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId, weekStart])
  @@index([seasonId, weekStart])
  @@index([userId, weekStart])
}

model AwardDefinition {
  id          String     @id @default(cuid())
  code        String     @unique @db.VarChar(64)
  name        String
  description String?    @db.Text
  scope       AwardScope @default(season)

  pointsBonus Int      @default(0)
  iconKey     String?  @db.VarChar(128)
  criteria    Json?

  category    String?  @db.VarChar(64)   // streak, volume, muscle, running, consistency, profile
  level       Int?                         // 1, 2, 3... si quieren badges escalables
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  earned AwardEarned[]
}

model AwardEarned {
  id         String   @id @default(cuid())
  awardId    String
  userId     String
  seasonId   String?
  activityId String?
  earnedAt   DateTime @default(now())
  metadata   Json?
  dedupeKey  String   @unique @db.VarChar(255)

  award    AwardDefinition @relation(fields: [awardId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  season   Season?         @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  activity Activity?       @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([seasonId, userId])
  @@index([activityId])
}